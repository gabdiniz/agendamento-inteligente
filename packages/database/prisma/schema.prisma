// =============================================================================
// MyAgendix — Prisma Schema
// Estratégia: schema-per-tenant no PostgreSQL
// O schema do tenant é resolvido dinamicamente em runtime via DATABASE_URL
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// SCHEMA PUBLIC — Tabelas da plataforma (tenants, planos, billing)
// Nota: As tabelas abaixo são do schema `public`.
// As tabelas de tenant ficam em schemas isolados e são gerenciadas
// via migrations dinâmicas por tenant (ver src/tenant-migrations.ts)
// =============================================================================

// ─── Enums (compartilhados) ─────────────────────────────────────────────────

enum PlanType {
  BASIC
  PRO
}

enum Role {
  GESTOR
  PROFISSIONAL
  RECEPCAO
}

enum AppointmentStatus {
  SCHEDULED
  PATIENT_PRESENT
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum CanceledBy {
  PATIENT
  STAFF
}

enum WaitlistStatus {
  WAITING
  NOTIFIED
  CONFIRMED
  EXPIRED
  REMOVED
}

enum NotificationType {
  APPOINTMENT_CONFIRMATION
  APPOINTMENT_REMINDER
  WAITLIST_VACANCY
  CAMPAIGN
  RETENTION_SUGGESTION
  CUSTOM
}

enum NotificationChannel {
  WHATSAPP
  SMS
  EMAIL
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

enum PatientSource {
  MANUAL
  PUBLIC_PAGE
  INVITE
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

// MVP2 — CRM
enum PatientClassification {
  BRONZE
  SILVER
  GOLD
}

enum PatientInterestType {
  PROCEDURE
  AREA
}

// MVP2
enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum CommunicationTone {
  FORMAL
  CASUAL
  FRIENDLY
}

enum ConversationStatus {
  OPEN
  CLOSED
}

enum MessageSenderType {
  PATIENT
  USER
  AI
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELED
}

// =============================================================================
// SCHEMA PUBLIC
// =============================================================================

model Tenant {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String    @db.VarChar(255)
  slug      String    @unique @db.VarChar(100)
  email     String    @db.VarChar(255)
  phone     String?   @db.VarChar(20)
  logoUrl   String?
  address   String?
  planType  PlanType  @default(BASIC)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now()) @db.Timestamptz
  updatedAt DateTime  @updatedAt @db.Timestamptz

  // MVP2
  subscriptions Subscription[]

  @@index([isActive])
  @@map("tenants")
}

model SuperAdminUser {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String   @db.VarChar(255)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @db.VarChar(255)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt @db.Timestamptz

  refreshTokens SuperAdminRefreshToken[]

  @@map("super_admin_users")
}

model SuperAdminRefreshToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @db.VarChar(255)
  expiresAt DateTime  @db.Timestamptz
  revokedAt DateTime? @db.Timestamptz
  createdAt DateTime  @default(now()) @db.Timestamptz

  user SuperAdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tokenHash])
  @@index([userId])
  @@map("super_admin_refresh_tokens")
}

// ─── MVP2: Billing ──────────────────────────────────────────────────────────

model Plan {
  id                       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                     String   @db.VarChar(100)
  slug                     String   @unique @db.VarChar(50)
  description              String?
  priceMonthyCents         Int
  priceYearlyCents         Int?
  maxProfessionals         Int      @default(5)
  maxMonthlyAppointments   Int      @default(200)
  features                 Json     @default("{}")
  isActive                 Boolean  @default(true)
  createdAt                DateTime @default(now()) @db.Timestamptz
  updatedAt                DateTime @updatedAt @db.Timestamptz

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                      String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId                String             @db.Uuid
  planId                  String             @db.Uuid
  status                  SubscriptionStatus @default(TRIALING)
  billingCycle            BillingCycle       @default(MONTHLY)
  currentPeriodStart      DateTime           @db.Timestamptz
  currentPeriodEnd        DateTime           @db.Timestamptz
  externalSubscriptionId  String?            @db.VarChar(255)
  externalCustomerId      String?            @db.VarChar(255)
  canceledAt              DateTime?          @db.Timestamptz
  createdAt               DateTime           @default(now()) @db.Timestamptz
  updatedAt               DateTime           @updatedAt @db.Timestamptz

  tenant   Tenant @relation(fields: [tenantId], references: [id])
  plan     Plan   @relation(fields: [planId], references: [id])
  invoices Invoice[]

  @@index([tenantId])
  @@index([externalSubscriptionId])
  @@map("subscriptions")
}

model PaymentMethod {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @db.VarChar(100)
  type           String   @db.VarChar(20)
  externalToken  String   @db.VarChar(255)
  lastFourDigits String?  @db.VarChar(4)
  brand          String?  @db.VarChar(50)
  isDefault      Boolean  @default(false)
  expiresAt      DateTime? @db.Date
  createdAt      DateTime @default(now()) @db.Timestamptz

  @@index([tenantId])
  @@map("payment_methods")
}

model Invoice {
  id                 String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscriptionId     String       @db.Uuid
  externalInvoiceId  String?      @db.VarChar(255)
  amountCents        Int
  status             String       @db.VarChar(20)
  billingCycle       BillingCycle
  periodStart        DateTime     @db.Timestamptz
  periodEnd          DateTime     @db.Timestamptz
  paidAt             DateTime?    @db.Timestamptz
  failedReason       String?
  createdAt          DateTime     @default(now()) @db.Timestamptz

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
  @@index([externalInvoiceId])
  @@map("invoices")
}

// =============================================================================
// SCHEMA TENANT
// As tabelas abaixo são replicadas em cada schema de tenant.
// Em runtime, o Prisma client aponta para o schema correto via search_path.
// =============================================================================

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String   @db.VarChar(255)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @db.VarChar(255)
  phone        String?  @db.VarChar(20)
  avatarUrl    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt @db.Timestamptz

  roles         UserRole[]
  refreshTokens RefreshToken[]
  professional  Professional?

  createdAppointments     Appointment[]           @relation("AppointmentCreatedBy")
  statusHistoryChanges    AppointmentStatusHistory[]
  scheduleBlocksCreated   ScheduleBlock[]
  patientEvaluations      PatientEvaluation[]
  conversationsAssigned   Conversation[]
  campaignsCreated        Campaign[]

  @@index([isActive])
  @@map("users")
}

model UserRole {
  userId String @db.Uuid
  role   Role

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, role])
  @@map("user_roles")
}

model RefreshToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @db.Uuid
  tokenHash  String    @db.VarChar(255)
  expiresAt  DateTime  @db.Timestamptz
  revokedAt  DateTime? @db.Timestamptz
  createdAt  DateTime  @default(now()) @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tokenHash])
  @@index([userId])
  @@map("refresh_tokens")
}

model Professional {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?  @unique @db.Uuid
  name      String   @db.VarChar(255)
  specialty String?  @db.VarChar(255)
  bio       String?
  avatarUrl String?
  color     String?  @db.VarChar(7)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  user       User?   @relation(fields: [userId], references: [id])

  procedures     ProfessionalProcedure[]
  workSchedules  WorkSchedule[]
  scheduleBlocks ScheduleBlock[]
  appointments   Appointment[]
  waitlistEntries WaitlistEntry[]
  appointmentEvaluations AppointmentEvaluation[]

  @@index([isActive])
  @@map("professionals")
}

model Procedure {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String   @db.VarChar(255)
  description     String?
  durationMinutes Int
  color           String?  @db.VarChar(7)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz

  professionals ProfessionalProcedure[]
  appointments  Appointment[]
  waitlistEntries WaitlistEntry[]

  @@map("procedures")
}

model ProfessionalProcedure {
  professionalId String @db.Uuid
  procedureId    String @db.Uuid

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  procedure    Procedure    @relation(fields: [procedureId], references: [id], onDelete: Cascade)

  @@id([professionalId, procedureId])
  @@map("professional_procedures")
}

model WorkSchedule {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  professionalId       String   @db.Uuid
  dayOfWeek            Int      @db.SmallInt
  startTime            DateTime @db.Time
  endTime              DateTime @db.Time
  slotIntervalMinutes  Int      @default(30)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now()) @db.Timestamptz
  updatedAt            DateTime @updatedAt @db.Timestamptz

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([professionalId, dayOfWeek])
  @@map("work_schedules")
}

model ScheduleBlock {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  professionalId   String   @db.Uuid
  startDatetime    DateTime @db.Timestamptz
  endDatetime      DateTime @db.Timestamptz
  reason           String?
  createdByUserId  String   @db.Uuid
  createdAt        DateTime @default(now()) @db.Timestamptz

  professional  Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  createdByUser User         @relation(fields: [createdByUserId], references: [id])

  @@index([professionalId])
  @@index([startDatetime, endDatetime])
  @@map("schedule_blocks")
}

model Patient {
  id                         String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                       String               @db.VarChar(255)
  phone                      String               @unique @db.VarChar(20)
  email                      String?              @db.VarChar(255)
  birthDate                  DateTime?            @db.Date
  gender                     Gender?
  city                       String?              @db.VarChar(255)
  preferredContactChannel    NotificationChannel?
  preferredContactTimeStart  DateTime?            @db.Time
  preferredDaysOfWeek        Int[]                @db.SmallInt
  marketingOptIn             Boolean              @default(false)
  notes                      String?
  source                     PatientSource        @default(MANUAL)
  isActive                   Boolean              @default(true)
  createdAt                  DateTime             @default(now()) @db.Timestamptz
  updatedAt                  DateTime             @updatedAt @db.Timestamptz

  appointments           Appointment[]
  waitlistEntries        WaitlistEntry[]
  notifications          Notification[]
  evaluations            PatientEvaluation[]
  appointmentEvaluations AppointmentEvaluation[]
  conversations          Conversation[]

  // MVP2 — CRM
  interests  PatientInterest[]
  crmMetrics PatientCrmMetrics?

  @@index([isActive])
  @@index([birthDate])
  @@map("patients")
}

// MVP2 — CRM
model PatientInterest {
  id        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId String              @db.Uuid
  type      PatientInterestType
  value     String              @db.VarChar(255)
  createdAt DateTime            @default(now()) @db.Timestamptz

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([type, value])
  @@map("patient_interests")
}

model PatientEvaluation {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId         String   @db.Uuid
  createdByUserId   String   @db.Uuid
  notes             String
  tags              String[]
  createdAt         DateTime @default(now()) @db.Timestamptz
  updatedAt         DateTime @updatedAt @db.Timestamptz

  patient       Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  createdByUser User    @relation(fields: [createdByUserId], references: [id])

  @@index([patientId])
  @@map("patient_evaluations")
}

model Appointment {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId          String            @db.Uuid
  professionalId     String            @db.Uuid
  procedureId        String            @db.Uuid
  scheduledDate      DateTime          @db.Date
  startTime          DateTime          @db.Time
  endTime            DateTime          @db.Time
  status             AppointmentStatus @default(SCHEDULED)
  cancellationReason String?
  canceledBy         CanceledBy?
  notes              String?
  createdByUserId    String?           @db.Uuid
  createdAt          DateTime          @default(now()) @db.Timestamptz
  updatedAt          DateTime          @updatedAt @db.Timestamptz

  patient       Patient      @relation(fields: [patientId], references: [id])
  professional  Professional @relation(fields: [professionalId], references: [id])
  procedure     Procedure    @relation(fields: [procedureId], references: [id])
  createdByUser User?        @relation("AppointmentCreatedBy", fields: [createdByUserId], references: [id])

  statusHistory       AppointmentStatusHistory[]
  evaluation          AppointmentEvaluation?
  waitlistEntry       WaitlistEntry?
  notifications       Notification[]

  @@index([professionalId, scheduledDate])
  @@index([patientId])
  @@index([status])
  @@index([scheduledDate])
  @@map("appointments")
}

model AppointmentStatusHistory {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  appointmentId     String            @db.Uuid
  status            AppointmentStatus
  changedByUserId   String?           @db.Uuid
  notes             String?
  changedAt         DateTime          @default(now()) @db.Timestamptz

  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  changedByUser User?       @relation(fields: [changedByUserId], references: [id])

  @@index([appointmentId])
  @@map("appointment_status_history")
}

model WaitlistEntry {
  id                  String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId           String         @db.Uuid
  professionalId      String?        @db.Uuid
  procedureId         String         @db.Uuid
  preferredDateFrom   DateTime?      @db.Date
  preferredDateTo     DateTime?      @db.Date
  minAdvanceMinutes   Int            @default(60)
  status              WaitlistStatus @default(WAITING)
  notifiedAt          DateTime?      @db.Timestamptz
  confirmedAt         DateTime?      @db.Timestamptz
  expiresAt           DateTime?      @db.Timestamptz
  appointmentId       String?        @unique @db.Uuid
  createdAt           DateTime       @default(now()) @db.Timestamptz
  updatedAt           DateTime       @updatedAt @db.Timestamptz

  patient      Patient      @relation(fields: [patientId], references: [id])
  professional Professional? @relation(fields: [professionalId], references: [id])
  procedure    Procedure    @relation(fields: [procedureId], references: [id])
  appointment  Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([status])
  @@index([patientId])
  @@index([professionalId, procedureId])
  @@map("waitlist_entries")
}

model Notification {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId      String?             @db.Uuid
  userId         String?             @db.Uuid
  type           NotificationType
  channel        NotificationChannel
  recipient      String              @db.VarChar(255)
  content        String
  status         NotificationStatus  @default(PENDING)
  appointmentId  String?             @db.Uuid
  externalId     String?             @db.VarChar(255)
  sentAt         DateTime?           @db.Timestamptz
  failedReason   String?
  createdAt      DateTime            @default(now()) @db.Timestamptz

  patient     Patient?     @relation(fields: [patientId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([patientId])
  @@index([status])
  @@index([appointmentId])
  @@index([type])
  @@map("notifications")
}

model AppointmentEvaluation {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  appointmentId  String   @unique @db.Uuid
  patientId      String   @db.Uuid
  professionalId String   @db.Uuid
  rating         Int      @db.SmallInt
  comment        String?
  createdAt      DateTime @default(now()) @db.Timestamptz

  appointment  Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patient      Patient      @relation(fields: [patientId], references: [id])
  professional Professional @relation(fields: [professionalId], references: [id])

  @@index([professionalId])
  @@index([rating])
  @@map("appointment_evaluations")
}

// =============================================================================
// MVP2 — Tabelas criadas agora, implementadas no MVP2
// =============================================================================

// ─── CRM ────────────────────────────────────────────────────────────────────

model PatientCrmMetrics {
  id                       String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId                String                @unique @db.Uuid
  totalAppointments        Int                   @default(0)
  lastAppointmentAt        DateTime?             @db.Timestamptz
  cancellationCount        Int                   @default(0)
  classification           PatientClassification @default(BRONZE)
  preferredAppointmentHour Int?                  @db.SmallInt
  updatedAt                DateTime              @default(now()) @updatedAt @db.Timestamptz

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([classification])
  @@map("patient_crm_metrics")
}

model AiConfig {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assistantName     String            @default("Assistente") @db.VarChar(100)
  communicationTone CommunicationTone @default(FRIENDLY)
  welcomeMessage    String?
  faq               Json              @default("[]")
  isActive          Boolean           @default(false)
  createdAt         DateTime          @default(now()) @db.Timestamptz
  updatedAt         DateTime          @updatedAt @db.Timestamptz

  @@map("ai_config")
}

model Conversation {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId      String             @db.Uuid
  assignedUserId String?            @db.Uuid
  status         ConversationStatus @default(OPEN)
  createdAt      DateTime           @default(now()) @db.Timestamptz
  updatedAt      DateTime           @updatedAt @db.Timestamptz

  patient      Patient  @relation(fields: [patientId], references: [id])
  assignedUser User?    @relation(fields: [assignedUserId], references: [id])
  messages     Message[]

  @@index([patientId])
  @@index([status])
  @@map("conversations")
}

model Message {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String            @db.Uuid
  senderType     MessageSenderType
  senderId       String?           @db.Uuid
  content        String
  readAt         DateTime?         @db.Timestamptz
  sentAt         DateTime          @default(now()) @db.Timestamptz

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([sentAt])
  @@map("messages")
}

model Campaign {
  id                String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title             String         @db.VarChar(255)
  content           String
  channel           NotificationChannel
  targetSegment     Json?
  status            CampaignStatus @default(DRAFT)
  scheduledAt       DateTime?      @db.Timestamptz
  sentAt            DateTime?      @db.Timestamptz
  createdByUserId   String         @db.Uuid
  createdAt         DateTime       @default(now()) @db.Timestamptz
  updatedAt         DateTime       @updatedAt @db.Timestamptz

  createdByUser User               @relation(fields: [createdByUserId], references: [id])
  recipients    CampaignRecipient[]

  @@map("campaigns")
}

model CampaignRecipient {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId  String   @db.Uuid
  patientId   String   @db.Uuid
  status      String   @default("PENDING") @db.VarChar(20)
  sentAt      DateTime? @db.Timestamptz

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, patientId])
  @@index([campaignId])
  @@map("campaign_recipients")
}
