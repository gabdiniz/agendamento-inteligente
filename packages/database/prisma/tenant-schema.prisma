// =============================================================================
// MyAgendix — Tenant Schema (usado APENAS para prisma db push)
//
// Este arquivo contém SOMENTE os modelos que devem ser criados em cada
// schema isolado de tenant no PostgreSQL.
//
// NÃO é usado para `prisma generate` (o client é gerado a partir de schema.prisma).
// É usado exclusivamente por `create-tenant-schema.ts` via `prisma db push`.
// =============================================================================

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums usados pelos modelos de tenant ────────────────────────────────────

enum Role {
  GESTOR
  PROFISSIONAL
  RECEPCAO
}

enum AppointmentStatus {
  SCHEDULED
  PATIENT_PRESENT
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum CanceledBy {
  PATIENT
  STAFF
}

enum WaitlistStatus {
  WAITING
  NOTIFIED
  CONFIRMED
  EXPIRED
  REMOVED
}

enum NotificationType {
  APPOINTMENT_CONFIRMATION
  APPOINTMENT_REMINDER
  WAITLIST_VACANCY
  CAMPAIGN
  RETENTION_SUGGESTION
  CUSTOM
}

enum NotificationChannel {
  WHATSAPP
  SMS
  EMAIL
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

enum PatientSource {
  MANUAL
  PUBLIC_PAGE
  INVITE
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum PatientClassification {
  BRONZE
  SILVER
  GOLD
}

enum PatientInterestType {
  PROCEDURE
  AREA
}

enum CommunicationTone {
  FORMAL
  CASUAL
  FRIENDLY
}

enum ConversationStatus {
  OPEN
  CLOSED
}

enum MessageSenderType {
  PATIENT
  USER
  AI
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELED
}

enum QuickRating {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

// ─── Tenant models ────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String   @db.VarChar(255)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @db.VarChar(255)
  phone        String?  @db.VarChar(20)
  avatarUrl    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt @db.Timestamptz

  roles         UserRole[]
  refreshTokens RefreshToken[]
  professional  Professional?

  createdAppointments  Appointment[]              @relation("AppointmentCreatedBy")
  statusHistoryChanges AppointmentStatusHistory[]
  scheduleBlocksCreated ScheduleBlock[]
  patientEvaluations   PatientEvaluation[]
  conversationsAssigned Conversation[]
  campaignsCreated     Campaign[]

  @@index([isActive])
  @@map("users")
}

model UserRole {
  userId String @db.Uuid
  role   Role

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, role])
  @@map("user_roles")
}

model RefreshToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @db.VarChar(255)
  expiresAt DateTime  @db.Timestamptz
  revokedAt DateTime? @db.Timestamptz
  createdAt DateTime  @default(now()) @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tokenHash])
  @@index([userId])
  @@map("refresh_tokens")
}

model Professional {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?  @unique @db.Uuid
  name      String   @db.VarChar(255)
  specialty String?  @db.VarChar(255)
  bio       String?
  avatarUrl String?
  color     String?  @db.VarChar(7)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  user User? @relation(fields: [userId], references: [id])

  procedures             ProfessionalProcedure[]
  workSchedules          WorkSchedule[]
  scheduleBlocks         ScheduleBlock[]
  appointments           Appointment[]
  waitlistEntries        WaitlistEntry[]
  appointmentEvaluations AppointmentEvaluation[]

  @@index([isActive])
  @@map("professionals")
}

model Procedure {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String   @db.VarChar(255)
  description     String?
  durationMinutes Int
  priceCents               Int?
  preparationInstructions  String?
  color           String?  @db.VarChar(7)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz

  professionals   ProfessionalProcedure[]
  appointments    Appointment[]
  waitlistEntries WaitlistEntry[]

  @@map("procedures")
}

model ProfessionalProcedure {
  professionalId String @db.Uuid
  procedureId    String @db.Uuid

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  procedure    Procedure    @relation(fields: [procedureId], references: [id], onDelete: Cascade)

  @@id([professionalId, procedureId])
  @@map("professional_procedures")
}

model WorkSchedule {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  professionalId      String   @db.Uuid
  dayOfWeek           Int      @db.SmallInt
  startTime           DateTime @db.Time
  endTime             DateTime @db.Time
  slotIntervalMinutes Int      @default(30)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now()) @db.Timestamptz
  updatedAt           DateTime @updatedAt @db.Timestamptz

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([professionalId, dayOfWeek])
  @@map("work_schedules")
}

model ScheduleBlock {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  professionalId  String   @db.Uuid
  startDatetime   DateTime @db.Timestamptz
  endDatetime     DateTime @db.Timestamptz
  reason          String?
  createdByUserId String   @db.Uuid
  createdAt       DateTime @default(now()) @db.Timestamptz

  professional  Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  createdByUser User         @relation(fields: [createdByUserId], references: [id])

  @@index([professionalId])
  @@index([startDatetime, endDatetime])
  @@map("schedule_blocks")
}

model Patient {
  id                        String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                      String               @db.VarChar(255)
  phone                     String               @unique @db.VarChar(20)
  email                     String?              @db.VarChar(255)
  birthDate                 DateTime?            @db.Date
  gender                    Gender?
  city                      String?              @db.VarChar(255)
  preferredContactChannel   NotificationChannel?
  preferredContactTimeStart DateTime?            @db.Time
  preferredDaysOfWeek       Int[]                @db.SmallInt
  marketingOptIn            Boolean              @default(false)
  notes                     String?
  source                    PatientSource        @default(MANUAL)
  isActive                  Boolean              @default(true)
  createdAt                 DateTime             @default(now()) @db.Timestamptz
  updatedAt                 DateTime             @updatedAt @db.Timestamptz

  // ─── Portal do Paciente — Auth ────────────────────────────────────────────
  passwordHash              String?              @db.VarChar(255)
  emailVerifiedAt           DateTime?            @db.Timestamptz
  lastLoginAt               DateTime?            @db.Timestamptz
  passwordResetToken        String?              @unique @db.VarChar(255)
  passwordResetExpiresAt    DateTime?            @db.Timestamptz

  appointments           Appointment[]
  waitlistEntries        WaitlistEntry[]
  notifications          Notification[]
  evaluations            PatientEvaluation[]
  appointmentEvaluations AppointmentEvaluation[]
  conversations          Conversation[]
  interests              PatientInterest[]
  crmMetrics             PatientCrmMetrics?
  refreshTokens          PatientRefreshToken[]

  @@index([isActive])
  @@index([birthDate])
  @@index([email])
  @@map("patients")
}

model PatientInterest {
  id        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId String              @db.Uuid
  type      PatientInterestType
  value     String              @db.VarChar(255)
  createdAt DateTime            @default(now()) @db.Timestamptz

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([type, value])
  @@map("patient_interests")
}

model PatientEvaluation {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId       String   @db.Uuid
  createdByUserId String   @db.Uuid
  notes           String
  tags            String[]
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz

  patient       Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  createdByUser User    @relation(fields: [createdByUserId], references: [id])

  @@index([patientId])
  @@map("patient_evaluations")
}

model Appointment {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId          String            @db.Uuid
  professionalId     String            @db.Uuid
  procedureId        String            @db.Uuid
  scheduledDate      DateTime          @db.Date
  startTime          DateTime          @db.Time
  endTime            DateTime          @db.Time
  status             AppointmentStatus @default(SCHEDULED)
  cancellationReason String?
  canceledBy         CanceledBy?
  notes              String?
  createdByUserId    String?           @db.Uuid
  createdAt          DateTime          @default(now()) @db.Timestamptz
  updatedAt          DateTime          @updatedAt @db.Timestamptz

  patient       Patient      @relation(fields: [patientId], references: [id])
  professional  Professional @relation(fields: [professionalId], references: [id])
  procedure     Procedure    @relation(fields: [procedureId], references: [id])
  createdByUser User?        @relation("AppointmentCreatedBy", fields: [createdByUserId], references: [id])

  statusHistory AppointmentStatusHistory[]
  evaluation    AppointmentEvaluation?
  waitlistEntry WaitlistEntry?
  notifications Notification[]

  @@index([professionalId, scheduledDate])
  @@index([patientId])
  @@index([status])
  @@index([scheduledDate])
  @@map("appointments")
}

model AppointmentStatusHistory {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  appointmentId   String            @db.Uuid
  status          AppointmentStatus
  changedByUserId String?           @db.Uuid
  notes           String?
  changedAt       DateTime          @default(now()) @db.Timestamptz

  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  changedByUser User?       @relation(fields: [changedByUserId], references: [id])

  @@index([appointmentId])
  @@map("appointment_status_history")
}

model WaitlistEntry {
  id                String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId         String         @db.Uuid
  professionalId    String?        @db.Uuid
  procedureId       String         @db.Uuid
  preferredDateFrom DateTime?      @db.Date
  preferredDateTo   DateTime?      @db.Date
  minAdvanceMinutes Int            @default(60)
  status            WaitlistStatus @default(WAITING)
  notifiedAt        DateTime?      @db.Timestamptz
  confirmedAt       DateTime?      @db.Timestamptz
  expiresAt         DateTime?      @db.Timestamptz
  appointmentId     String?        @unique @db.Uuid
  createdAt         DateTime       @default(now()) @db.Timestamptz
  updatedAt         DateTime       @updatedAt @db.Timestamptz

  patient      Patient       @relation(fields: [patientId], references: [id])
  professional Professional? @relation(fields: [professionalId], references: [id])
  procedure    Procedure     @relation(fields: [procedureId], references: [id])
  appointment  Appointment?  @relation(fields: [appointmentId], references: [id])

  @@index([status])
  @@index([patientId])
  @@index([professionalId, procedureId])
  @@map("waitlist_entries")
}

model Notification {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId     String?             @db.Uuid
  userId        String?             @db.Uuid
  type          NotificationType
  channel       NotificationChannel
  recipient     String              @db.VarChar(255)
  content       String
  status        NotificationStatus  @default(PENDING)
  appointmentId String?             @db.Uuid
  externalId    String?             @db.VarChar(255)
  sentAt        DateTime?           @db.Timestamptz
  failedReason  String?
  createdAt     DateTime            @default(now()) @db.Timestamptz

  patient     Patient?     @relation(fields: [patientId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([patientId])
  @@index([status])
  @@index([appointmentId])
  @@index([type])
  @@map("notifications")
}

model AppointmentEvaluation {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  appointmentId  String       @unique @db.Uuid
  patientId      String       @db.Uuid
  professionalId String       @db.Uuid

  // ─── Momento 1 — Avaliação rápida (emoji) ─────────────────────────────────
  quickRating               QuickRating? // POSITIVE | NEUTRAL | NEGATIVE
  quickRatingReasons        String[]     @default([])
  detailedRatingRequestedAt DateTime?    @db.Timestamptz

  // ─── Momento 2 — Avaliação detalhada (opcional, 24h depois) ───────────────
  rating  Int?    @db.SmallInt  // 1–5 estrelas — null até avaliação detalhada
  comment String?

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  appointment  Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patient      Patient      @relation(fields: [patientId], references: [id])
  professional Professional @relation(fields: [professionalId], references: [id])

  @@index([professionalId])
  @@index([quickRating])
  @@index([rating])
  @@map("appointment_evaluations")
}

// ─── MVP2 — CRM ───────────────────────────────────────────────────────────────

model PatientCrmMetrics {
  id                       String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId                String                @unique @db.Uuid
  totalAppointments        Int                   @default(0)
  lastAppointmentAt        DateTime?             @db.Timestamptz
  cancellationCount        Int                   @default(0)
  classification           PatientClassification @default(BRONZE)
  preferredAppointmentHour Int?                  @db.SmallInt
  updatedAt                DateTime              @default(now()) @updatedAt @db.Timestamptz

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([classification])
  @@map("patient_crm_metrics")
}

model AiConfig {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assistantName     String            @default("Assistente") @db.VarChar(100)
  communicationTone CommunicationTone @default(FRIENDLY)
  welcomeMessage    String?
  faq               Json              @default("[]")
  isActive          Boolean           @default(false)
  createdAt         DateTime          @default(now()) @db.Timestamptz
  updatedAt         DateTime          @updatedAt @db.Timestamptz

  @@map("ai_config")
}

model Conversation {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId      String             @db.Uuid
  assignedUserId String?            @db.Uuid
  status         ConversationStatus @default(OPEN)
  createdAt      DateTime           @default(now()) @db.Timestamptz
  updatedAt      DateTime           @updatedAt @db.Timestamptz

  patient      Patient   @relation(fields: [patientId], references: [id])
  assignedUser User?     @relation(fields: [assignedUserId], references: [id])
  messages     Message[]

  @@index([patientId])
  @@index([status])
  @@map("conversations")
}

model Message {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String            @db.Uuid
  senderType     MessageSenderType
  senderId       String?           @db.Uuid
  content        String
  readAt         DateTime?         @db.Timestamptz
  sentAt         DateTime          @default(now()) @db.Timestamptz

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([sentAt])
  @@map("messages")
}

model Campaign {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title           String              @db.VarChar(255)
  content         String
  channel         NotificationChannel
  targetSegment   Json?
  status          CampaignStatus      @default(DRAFT)
  scheduledAt     DateTime?           @db.Timestamptz
  sentAt          DateTime?           @db.Timestamptz
  createdByUserId String              @db.Uuid
  createdAt       DateTime            @default(now()) @db.Timestamptz
  updatedAt       DateTime            @updatedAt @db.Timestamptz

  createdByUser User               @relation(fields: [createdByUserId], references: [id])
  recipients    CampaignRecipient[]

  @@map("campaigns")
}

model CampaignRecipient {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId String    @db.Uuid
  patientId  String    @db.Uuid
  status     String    @default("PENDING") @db.VarChar(20)
  sentAt     DateTime? @db.Timestamptz

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, patientId])
  @@index([campaignId])
  @@map("campaign_recipients")
}

// ─── Recuperação de senha ─────────────────────────────────────────────────────

model PasswordResetToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @db.VarChar(255)
  expiresAt DateTime  @db.Timestamptz
  usedAt    DateTime? @db.Timestamptz
  createdAt DateTime  @default(now()) @db.Timestamptz

  @@unique([tokenHash])
  @@index([userId])
  @@map("password_reset_tokens")
}

// ─── Portal do Paciente ───────────────────────────────────────────────────────

model PatientRefreshToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId String    @db.Uuid
  tokenHash String    @unique @db.VarChar(255)
  expiresAt DateTime  @db.Timestamptz
  revokedAt DateTime? @db.Timestamptz
  createdAt DateTime  @default(now()) @db.Timestamptz

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@map("patient_refresh_tokens")
}

model ClinicPatientConfig {
  id                            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cancellationAllowed           Boolean  @default(true)
  cancellationMinHoursInAdvance Int      @default(2)
  cancellationAllowedStatuses   String[] @default(["SCHEDULED"])
  createdAt                     DateTime @default(now()) @db.Timestamptz
  updatedAt                     DateTime @updatedAt @db.Timestamptz

  @@map("clinic_patient_configs")
}

// ─── WhatsApp / Z-API ─────────────────────────────────────────────────────────

enum WhatsappEvent {
  CONFIRMATION
  REMINDER
  CANCELLATION
  RESCHEDULE
}

enum WhatsappJobStatus {
  PENDING
  SENDING
  SENT
  FAILED
  CANCELED
}

model WhatsappTemplate {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event     WhatsappEvent @unique
  body      String
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now()) @db.Timestamptz
  updatedAt DateTime      @updatedAt @db.Timestamptz

  @@map("whatsapp_templates")
}

model WhatsappJob {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event         WhatsappEvent
  phone         String            @db.VarChar(20)
  message       String
  status        WhatsappJobStatus @default(PENDING)
  retries       Int               @default(0)
  scheduledAt   DateTime          @db.Timestamptz
  sentAt        DateTime?         @db.Timestamptz
  errorLog      String?
  appointmentId String            @db.Uuid
  patientName   String            @db.VarChar(255)
  createdAt     DateTime          @default(now()) @db.Timestamptz
  updatedAt     DateTime          @updatedAt @db.Timestamptz

  @@index([status, scheduledAt])
  @@map("whatsapp_jobs")
}
