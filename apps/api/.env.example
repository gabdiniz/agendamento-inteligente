# ─── App ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3333
API_URL=http://localhost:3333

# ─── Database ─────────────────────────────────────────────
# Schema `public` (tenants, planos, super admins)
DATABASE_URL=postgresql://myagendix:secret@localhost:5432/myagendix?schema=public

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-in-production-refresh
JWT_REFRESH_EXPIRES_IN=7d

# ─── Super Admin default (seed) ───────────────────────────
SUPER_ADMIN_EMAIL=admin@myagendix.com
SUPER_ADMIN_PASSWORD=change-me-in-production

# ─── MinIO ────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=myagendix
MINIO_USE_SSL=false

# ─── Notifications ────────────────────────────────────────
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
RESEND_API_KEY=

# ─── App URL ──────────────────────────────────────────────
APP_URL=http://localhost:5173
