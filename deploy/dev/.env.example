# ─── MyAgendix DEV — Variáveis de Ambiente ───────────────────────────────────
#
# Copie para .env e preencha os valores:
#   cp .env.example .env
#   nano .env
#
# ⚠️ NUNCA commitar o .env no git!
# ─────────────────────────────────────────────────────────────────────────────

# ── Banco de Dados ────────────────────────────────────────────────────────────
DB_USER=myagendix
DB_PASSWORD=TROQUE_ESSA_SENHA_FORTE
DB_NAME=myagendix

# ── Aplicação ─────────────────────────────────────────────────────────────────
APP_DOMAIN=dev.myagendix.com.br

# ── Secrets JWT ──────────────────────────────────────────────────────────────
# Gerar com: openssl rand -hex 64
JWT_SECRET=GERAR_COM_OPENSSL_RAND_HEX_64
JWT_REFRESH_SECRET=GERAR_COM_OPENSSL_RAND_HEX_64_DIFERENTE
SUPER_ADMIN_JWT_SECRET=GERAR_COM_OPENSSL_RAND_HEX_64_OUTRO

# ── E-mail (Resend) ───────────────────────────────────────────────────────────
# Obtenha sua API key em: https://resend.com/api-keys
RESEND_API_KEY=re_SUA_KEY_AQUI
# Remetente: deve ser um domínio verificado no Resend.
# Temporariamente use onboarding@resend.dev (só envia para o e-mail da conta Resend).
RESEND_FROM=noreply@seudominio.com.br
