# =============================================================================
# MyAgendix — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# =============================================================================

# ─── Banco de Dados ──────────────────────────────────────────────────────────
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://myagendix:myagendix@localhost:5432/myagendix?schema=public"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="substitua-por-uma-chave-segura-de-64-bytes-minimo"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="substitua-por-outra-chave-segura-diferente-da-de-cima"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3333
API_URL="http://localhost:3333"

# ─── MinIO (S3-compatible) ───────────────────────────────────────────────────
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="minio-access-key"
MINIO_SECRET_KEY="minio-secret-key"
MINIO_BUCKET="myagendix"
MINIO_USE_SSL=false

# ─── Notificações ────────────────────────────────────────────────────────────
# Z-API (WhatsApp)
ZAPI_INSTANCE_ID=""
ZAPI_TOKEN=""
ZAPI_CLIENT_TOKEN=""

# Twilio (SMS fallback)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Resend (Email)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@myagendix.com"

# ─── Frontend (Vite — prefixo VITE_ obrigatório) ─────────────────────────────
VITE_API_URL="http://localhost:3333"

# ─── MVP2 — IA ───────────────────────────────────────────────────────────────
# GEMINI_API_KEY=""

# ─── MVP2 — Billing ──────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# ASAAS_API_KEY=""
